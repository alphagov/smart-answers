<% text_for :title do %>
  <% if calculator.show_post_april_2026_policy_text? %>
    Enter the total amount (before deductions like Income Tax and National Insurance) of your employee’s earnings between <%= format_date(calculator.relevant_period_from) %> and <%= format_date(calculator.relevant_period_to) %>.
  <% else %>
    Enter the total amount (before deductions like Income Tax and National Insurance) of your employee’s earnings on paydays between <%= format_date(calculator.relevant_period_from) %> and <%= format_date(calculator.relevant_period_to) %>.
  <% end %>
<% end %>

<% govspeak_for :hint do %>
  Different rules apply to [directors of limited companies](/statutory-sick-pay-how-different-employment-types-affect-what-you-pay#directors)
<% end %>

<% text_for :error_message do %>
  Please enter a number greater than 0
<% end %>
