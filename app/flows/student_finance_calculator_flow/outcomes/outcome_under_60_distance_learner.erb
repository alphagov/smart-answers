<% govspeak_for :body do %>
  <%= render partial: 'disclaimer_lle' %>

  <% if calculator.attend_in_person == "no" && calculator.disability_status == "no" %>
    Because you are not attending the course in person, you are not eligible for a Maintenance Loan and some types of extra funding.
  <% end %>

  <%= render partial: 'tuition_summary_lle', locals: { tuition_fee_amount: calculator.tuition_fee_amount, tuition_fee_url: "/student-finance/new-fulltime-students", maintenance_loan_url: "/student-finance/new-fulltime-students", uk_ft_circumstances: calculator.uk_ft_circumstances, uk_all_circumstances: calculator.uk_all_circumstances, studied_before: calculator.studied_before == "yes", course_studied: calculator.course_studied } %>

  <%= render partial: 'extra_student_funding_lle', locals: { calculator: calculator } %>

  <%= render partial: 'uk_extra_help_lle', locals: { course_studied: calculator.course_studied, eligible_for_nhs_bursary: calculator.eligible_for_nhs_bursary == "yes" } %>

  <%= render partial: 'next_steps_lle' %>
<% end %>
