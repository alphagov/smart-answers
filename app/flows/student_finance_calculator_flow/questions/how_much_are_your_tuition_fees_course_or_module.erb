<% text_for :title do %>
  How much are your tuition fees for this year of your course or module?
<% end %>

<% text_for :hint do %>
    The maximum Tuition Fee Loan is <%= format_money(calculator.max_tuition_fee_amount) %> for a <%= calculator.part_time_credits.to_i %> credit course.
<% end %>

<% text_for :error_message do %>
    Please enter a number up to the maximum amount of <%= format_money(calculator.max_tuition_fee_amount) %>, don’t enter ‘£’
<% end %>
