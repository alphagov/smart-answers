<% text_for :title do %>
  How many credits a year does a full-time student study?
<% end %>

<% text_for :hint do %>
  Ask your university or college if you're not sure.
<% end %>

<% text_for :error_message do %>
  Please enter a whole number - decimals are not allowed
<% end %>

<% text_for :error_credit_amount do %>
  Please enter a number greater than or equal to your part-time study credits (<%= calculator.credits_studied %>)
<% end %>
