<% text_for :title do %>
  What's your annual household income?
<% end %>

<% text_for :hint do %>
  <% if calculator.age == "under-60" %>
    This is your parents’ or partner’s taxable income. It affects how much help you'll get with living costs.
  <% else %>
    This is your partner’s taxable income. It affects how much help you'll get with living costs.
  <% end %>
<% end %>

<% text_for :error_message do %>
  Enter a number - don’t use the £ sign.
<% end %>
