<% text_for :title do %>
  What's your annual household income?
<% end %>

<% text_for :hint do %>
  <% if calculator.age == "60-or-more" %>
    This is your partner’s taxable income  - your own income does not count. If you do not live with a partner, enter £0. It affects how much help you'll get with living costs.
  <% else %>
    This is your parents’ or partner’s taxable income - your own income does not count. If you do not live with your parents or a partner, enter £0. It affects how much help you'll get with living costs.
  <% end %>
<% end %>

<% text_for :error_message do %>
  Enter a number - don’t use the £ sign.
<% end %>
